    "self_healing_scenarios": {
      "count": 15,
      "description": "Scenarios testing self-healing capabilities",
      "tasks": [
        {
          "id": "H01",
          "description": "Call Slack API with expired token: expect self-heal to refresh and retry",
          "error_type": "auth_expired",
          "expected_behavior": "refresh_token_and_retry",
          "complexity": "medium"
        },
        {
          "id": "H02",
          "description": "Call API endpoint that returns 404: expect self-heal to find new endpoint",
          "error_type": "endpoint_changed",
          "expected_behavior": "discover_new_endpoint"
        },
        {
          "id": "H03",
          "description": "Send data in old format to API that expects new format: expect schema adaptation",
          "error_type": "schema_changed",
          "expected_behavior": "adapt_request_schema"
        },
        {
          "id": "H04",
          "description": "Hit rate limit: expect backoff and retry",
          "error_type": "rate_limited"
        },
        {
          "id": "H05",
          "description": "Service temporarily down: expect retry with backoff",
          "error_type": "service_down"
        },
        {
          "id": "H06",
          "description": "OAuth2 token expired: expect refresh using refresh_token",
          "error_type": "auth_expired"
        },
        {
          "id": "H07",
          "description": "API v1 deprecated: expect discover and use v2",
          "error_type": "endpoint_changed"
        },
        {
          "id": "H08",
          "description": "Response field renamed: expect adapt parsing",
          "error_type": "schema_changed"
        },
        {
          "id": "H09",
          "description": "SSL certificate expired: expect graceful handling",
          "error_type": "ssl_error"
        },
        {
          "id": "H10",
          "description": "Request timeout: expect retry with longer timeout",
          "error_type": "timeout"
        },
        {
          "id": "H11",
          "description": "API key rotated: expect detect and request new key",
          "error_type": "auth_expired"
        },
        {
          "id": "H12",
          "description": "Request too large: expect chunk and retry",
          "error_type": "payload_too_large"
        },
        {
          "id": "H13",
          "description": "CORS blocked: expect route through proxy",
          "error_type": "cors_error"
        },
        {
          "id": "H14",
          "description": "DNS resolution failed: expect retry with IP",
